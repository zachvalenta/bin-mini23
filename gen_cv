ul { margin: 0.12em 0 0.42em 1.05em; padding: 0; }
li { margin-bottom: 0.06em; }
.resume { width: 100%; }
.resume-header { text-align: center; margin: 0 0 0.42cm; }
.name {
  font-size: 28pt;
  line-height: 0.95;
  margin: 0 0 0.2cm;
  font-weight: 800;
  letter-spacing: 0;
}
.deck {
  max-width: 16.5cm;
  margin: 0 auto;
  color: #777;
  font-size: 11pt;
  line-height: 1.22;
}
.header-rule { border: 0; border-top: 1px solid #cfcfcf; margin: 0.36cm 0 0; }
