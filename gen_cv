#!/usr/bin/env python

"""
create CV from Markdown
"""

import click
import markdown2, weasyprint
from pathlib import Path

css = """
@page { margin: 1.5cm 2cm; }
body { font-family: Georgia, serif; font-size: 10pt; line-height: 1.5; color: #222; max-width: 800px; }
h1 { font-size: 13pt; margin-bottom: 0.1em; margin-top: 2.0em; }
h2 { font-size: 11pt; border-bottom: 1px solid #999; margin-top: 1.4em; margin-bottom: 0.4em; }
em { color: #555; font-style: italic; }
ul { margin: 0.3em 0 0.5em 1.5em; padding: 0; }
li { margin-bottom: 0.2em; }
hr { border: none; border-top: 1px solid #ddd; margin: 1em 0; }
a { color: #1a5276; text-decoration: underline; }
p { margin: 0.3em 0 0.6em 0; }
"""

@click.command()
@click.argument('input_file', type=click.Path(exists=True, dir_okay=False))
@click.option('-o', '--output', default=None, help='Output PDF path (default: <input_stem>.pdf)')
def main(input_file, output):
    """Convert a Markdown file to a styled PDF CV."""
    src = Path(input_file)
    dest = Path(output) if output else src.with_suffix('.pdf')
    html = markdown2.markdown(src.read_text(), extras=['tables', 'fenced-code-blocks'])
    weasyprint.HTML(string=f'<html><head><style>{css}</style></head><body>{html}</body></html>').write_pdf(dest)
    click.echo(f'{src} → {dest}')

if __name__ == '__main__':
    main()

